# Dev only — WebSocket connects directly to the FastAPI server.
# Vite's HMR handler intercepts WS upgrades before the proxy can forward them,
# so we bypass the proxy entirely for WebSocket connections.
VITE_WS_URL=ws://localhost:8000/api

# Google OAuth Client ID — get from Google Cloud Console
# https://console.cloud.google.com/ → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=876140482091-5vc5130v75fa038i38nro0la6gdlmr2r.apps.googleusercontent.com
